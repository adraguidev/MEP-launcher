FROM mcr.microsoft.com/powershell:lts-ubuntu-22.04

# Install sqlcmd (classic mssql-tools18)
RUN apt-get update && \
    apt-get install -y curl gnupg2 && \
    curl -fsSL https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor -o /usr/share/keyrings/microsoft-prod.gpg && \
    echo "deb [arch=amd64,arm64 signed-by=/usr/share/keyrings/microsoft-prod.gpg] https://packages.microsoft.com/ubuntu/22.04/prod jammy main" > /etc/apt/sources.list.d/mssql-release.list && \
    apt-get update && \
    ACCEPT_EULA=Y apt-get install -y mssql-tools18 unixodbc-dev && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

ENV PATH="${PATH}:/opt/mssql-tools18/bin"

# Wrapper: auto-add -C (trust cert) so original scripts work unmodified
RUN printf '#!/bin/bash\nexec /opt/mssql-tools18/bin/sqlcmd -C "$@"\n' > /usr/local/bin/sqlcmd && \
    chmod +x /usr/local/bin/sqlcmd

WORKDIR /mep
